{
  "manifest_version": 3,
  "name": "pwgen-browser",
  "version": "1.0.1",
  "icons": {
    "48": "images/icon48.png",
    "128": "images/icon128.png",
    "16": "images/icon16.png"
  },
  "permissions": ["storage", "sidePanel"],
  "action": {
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
